<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WakeUp" parent="android:Theme.Material.NoActionBar">
        <item name="android:colorPrimary">@color/primary</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.WakeUp.Splash" parent="Theme.WakeUp">
        <item name="android:windowSplashScreenBackground">@color/background</item>
    </style>

    <style name="Theme.WakeUp.FullScreen" parent="Theme.WakeUp">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
